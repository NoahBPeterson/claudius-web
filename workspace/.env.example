# Copy to .env and fill in. Both keys are only needed to RE-RUN the asset
# pipeline; the extension itself needs no keys.

# OpenRouter — image generation (stage 1, hero still). https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# fal.ai — image-to-video (stage 2, motion). https://fal.ai/dashboard/keys
FAL_KEY=REPLACE_ME
