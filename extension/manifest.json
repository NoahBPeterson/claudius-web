{
  "manifest_version": 3,
  "name": "Claudius Mascot",
  "version": "1.0.0",
  "description": "Perches the flower-headed Claude character on your claude.ai message box, happily kicking its feet. Unofficial fan project — not affiliated with Anthropic.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*", "https://*.claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["sprite.webp"],
      "matches": ["https://claude.ai/*", "https://*.claude.ai/*"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "claudius-mascot@claudius-web",
      "strict_min_version": "115.0",
      "data_collection_permissions": { "required": ["none"] }
    }
  }
}
